# Copy this file to .env and fill in real values. Never commit .env.

# --- LLM provider (used by the agent layer) ---
# Set the provider you actually use. The agent reads these at runtime.
LLM_PROVIDER=openrouter            # one of: openrouter | anthropic | ollama
LLM_API_KEY=                       # API key for the chosen provider
LLM_MODEL=anthropic/claude-3.5-sonnet
LLM_BASE_URL=https://openrouter.ai/api/v1

# --- MCP server ---
MCP_PROJECT_ROOT=.                 # directory the MCP server is allowed to read

# --- Memory (Obsidian vault) ---
# Absolute path to your Obsidian vault. When set, Hermes recalls relevant notes.
MEMORY_VAULT=
OBSIDIAN_VAULT=                    # alias for MEMORY_VAULT

# --- BLAST app ---
AUTH_SECRET=                       # long random string for signing session tokens
APP_URL=http://localhost:3000
DATABASE_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
