# Copy this file to .env and fill in real values. Never commit .env.

# --- LLM provider (used by the agent layer) ---
# Set the provider you actually use. The agent reads these at runtime.
LLM_PROVIDER=openrouter            # one of: openrouter | anthropic | ollama
LLM_API_KEY=                       # API key for the chosen provider
LLM_MODEL=anthropic/claude-3.5-sonnet
LLM_BASE_URL=https://openrouter.ai/api/v1

# --- MCP server ---
MCP_PROJECT_ROOT=.                 # directory the MCP server is allowed to read

# --- Memory (Obsidian vault) ---
# Absolute path to your Obsidian vault. When set, Hermes recalls relevant notes.
MEMORY_VAULT=
OBSIDIAN_VAULT=                    # alias for MEMORY_VAULT
MEMORY_BACKEND=bm25                # one of: bm25 | vector | hybrid

# --- Embeddings (used by vector / hybrid memory backends) ---
EMBEDDING_PROVIDER=mock            # one of: mock | openai | ollama
EMBEDDING_API_KEY=                 # falls back to LLM_API_KEY if unset
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1

# --- BLAST app ---
AUTH_SECRET=                       # long random string for signing session tokens
APP_URL=http://localhost:3000
# DATABASE_URL: set for Postgres/Supabase; leave empty for in-memory dev store.
# Supabase example: postgres://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=
PGSSL=                             # set to "disable" for a local DB without SSL
# STRIPE: set the secret key AND `npm i stripe` in src/backend to enable live mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
